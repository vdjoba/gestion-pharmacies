{
  "name": "pharmacy-app",
  "private": true,
  "version": "0.0.0",
  "description": "Gestion pharmacies - portail client web et administration desktop",
  "author": "Codex",
  "type": "commonjs",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "vite",
    "build:css": "tailwindcss build src/styles.css -o dist/styles.css",
    "desktop:dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "desktop:build": "npm run build",
    "desktop:start": "cross-env VITE_APP_MODE=desktop electron .",
    "desktop:pack": "npm run build && electron-builder --config electron-builder.cjs --dir",
    "desktop:win": "npm run build && electron-builder --config electron-builder.cjs --win nsis"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "axios": "^1.11.0",
    "electron-updater": "^6.8.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/axios": "^0.9.36",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.3",
    "wait-on": "^8.0.3"
  }
}
